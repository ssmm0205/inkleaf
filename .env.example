# Inkleaf — copy to `.env` and fill in to enable Google Tasks/Calendar sync.
# With these unset, Inkleaf runs normally with sync disabled.
#
# Create a Google Cloud OAuth client (type: "Desktop app") with the
# Google Tasks API + Google Calendar API enabled, and publish the OAuth
# consent screen to "Production" (the scopes are non-sensitive, so no review)
# to avoid the 7-day refresh-token expiry of "Testing" mode.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional overrides
# INKLEAF_PORT=8788
# INKLEAF_DB=inkleaf.db
# INKLEAF_SYNC_WINDOW_DAYS=14
