{
  "name": "inkleaf",
  "version": "0.1.0",
  "private": false,
  "description": "A local-first note-taking app that looks and feels like a handwritten paper notebook, with an MCP server that lets Claude read and write into your notes.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "notes",
    "note-taking",
    "handwriting",
    "ink",
    "mcp",
    "claude",
    "ai-agent",
    "local-first",
    "react",
    "typescript",
    "sqlite",
    "pwa"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -n server,ui -c green,cyan \"npm:dev:server\" \"npm:dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite",
    "mcp": "tsx src/mcp/server.ts",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.10.0",
    "google-auth-library": "^10.7.0",
    "googleapis": "^173.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@fontsource/nanum-pen-script": "^5.2.5",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
